[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://src/finale/shop_panel.gd" id="1"]

[node name="ShopPanel" type="PanelContainer"]
custom_minimum_size = Vector2(480, 0)
theme_type_variation = &"CardPanel"
script = ExtResource("1")

[node name="Column" type="VBoxContainer" parent="."]
layout_mode = 2
theme_override_constants/separation = 12

[node name="ShopTitle" type="Label" parent="Column"]
layout_mode = 2
theme_type_variation = &"TitleLabel"
text = "The Gauntlet — Buy-In"
horizontal_alignment = 1

[node name="ShopSubtitle" type="Label" parent="Column"]
layout_mode = 2
theme_type_variation = &"DimLabel"
text = "Spend your coins on survival power"
horizontal_alignment = 1

[node name="ShopTimeLabel" type="Label" parent="Column"]
unique_name_in_owner = true
layout_mode = 2
theme_type_variation = &"HeaderLabel"
horizontal_alignment = 1

[node name="ShopCoinsLabel" type="Label" parent="Column"]
unique_name_in_owner = true
layout_mode = 2
theme_type_variation = &"HintLabel"
horizontal_alignment = 1

[node name="ShopItems" type="VBoxContainer" parent="Column"]
unique_name_in_owner = true
layout_mode = 2
theme_override_constants/separation = 8

[node name="ShopConfirmButton" type="Button" parent="Column"]
unique_name_in_owner = true
layout_mode = 2
text = "Lock in"

[node name="ShopConfirmedLabel" type="Label" parent="Column"]
unique_name_in_owner = true
layout_mode = 2
theme_type_variation = &"SmallLabel"
horizontal_alignment = 1
